rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user has admin permission
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user has manageUsers permission
    function canManageUsers() {
      return request.auth != null &&
        ('manageUsers' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions ||
         'admin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions);
    }

    // Helper: check if the authenticated user has a specific permission or is admin
    function userHasPerm(perm) {
      return request.auth != null &&
        (perm in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions ||
         'admin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions);
    }

    // Users: Can read any profile, create/update their own, admins can update any
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && 
        (request.auth.uid == userId || canManageUsers());
      allow delete: if false; // Only admins via functions
    }

    // Events: Authenticated users can read their own events and those shared with them.
    // The creator (ownerId) OR an assigned manager (managerId) can update or delete.
    match /events/{eventId} {
      // Allow read if user is authenticated (query filtering happens in app)
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.managerId == request.auth.uid
      );
      allow delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.managerId == request.auth.uid
      );
    }

    // Stakeholders: Permission-gated CRUD.
    match /stakeholders/{stakeholderId} {
      allow read: if userHasPerm('viewStakeholder');
      allow create: if userHasPerm('createStakeholder');
      allow update: if userHasPerm('editStakeholder');
      allow delete: if userHasPerm('deleteStakeholder');
    }

    // EventStakeholders: Authenticated users can link/unlink stakeholders.
    match /eventStakeholders/{docId} {
      allow read, create, delete: if request.auth != null;
    }

    // Notifications: Users can only read and update their own notifications.
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Invites: Read-only for authenticated users to validate tokens
    // Write access only via Cloud Functions
    match /invites/{inviteId} {
      allow read: if request.auth != null;
      allow write: if false; // Only via Cloud Functions
    }

    // Audit Logs: Admin read-only; writes only via Cloud Functions
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only via Cloud Functions
    }
  }
}