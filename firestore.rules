rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if caller is an admin or root
    function isAdmin() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null &&
        (u.role == 'admin' || u.role == 'root' ||
         'admin' in u.permissions || 'root' in u.permissions);
    }

    // Helper: check if caller has manageUsers permission or is admin/root
    function canManageUsers() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null &&
        ('manageUsers' in u.permissions || 'admin' in u.permissions ||
         u.role == 'admin' || u.role == 'root');
    }

    // Helper: check if the authenticated user has a specific permission or is admin
    function userHasPerm(perm) {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null &&
        (perm in u.permissions || 'admin' in u.permissions);
    }

    // Users: readable by all authenticated users; self-update allowed but
    // role/permissions fields are locked (only Cloud Functions can change those)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        (request.auth.uid == userId || canManageUsers()) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'permissions']);
      allow delete: if false;
    }

    // Events: auth-required reads; only owner or manager can mutate
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.managerId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.managerId == request.auth.uid ||
        isAdmin()
      );
    }

    // Stakeholders: permission-gated CRUD
    match /stakeholders/{stakeholderId} {
      allow read: if userHasPerm('viewStakeholder');
      allow create: if userHasPerm('createStakeholder');
      allow update: if userHasPerm('editStakeholder');
      allow delete: if userHasPerm('deleteStakeholder');
    }

    // EventStakeholders: permission-gated (viewStakeholder to read)
    match /eventStakeholders/{docId} {
      allow read: if userHasPerm('viewStakeholder');
      allow create, update, delete: if userHasPerm('editStakeholder');
    }

    // Notifications: users read/update their own; writes only via Cloud Functions
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create, delete: if false;
    }

    // Invites: read-only for authenticated users; writes only via Cloud Functions
    match /invites/{inviteId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Audit Logs: admin read-only; writes only via Cloud Functions
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
